---
import "../styles/global.css";
import LoginButton from "../components/LoginButton.svelte";
import LoginModal from "../components/LoginModal.svelte";
import DeleteModal from "../components/DeleteModal.svelte";
import LoginWarning from "../components/LoginWarning.svelte";
--- 

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/z.svg" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Z-Links</title>
  </head>
  <body class="overflow-x-hidden">
    <header
      class="relative px-8 w-full h-20 max-w-5xl mx-auto grid grid-cols-[1fr_max-content_1fr] place-content-center"
    >
      <a
        href="/"
        class="col-start-2 justify-self-center flex items-center py-2"
      >
        <img src="/z.svg" alt="Z-Links Logo" class="size-16" />
        <h1
          class="text-3xl text-[lavender] translate-x-[-2rem] translate-y-[-0.3rem] tracking-wide"
        >
          Links
        </h1>
      </a>
      <LoginButton client:load />
    </header>
    <LoginModal client:load />
    <DeleteModal client:load />
    <LoginWarning client:load />
    <div class="min-h-[calc(100vh-10rem)]">
      <slot />
    </div>
    <footer class="w-full h-20 bg-gray-950 border-t border-purple-700/30 ">
      <div class="max-w-5xl mx-auto px-8 h-full flex items-center">
      <div class="flex items-center justify-between w-full">
      <p class="text-lavender/60 text-xs">
      © 2024 Z-Links. All rights reserved.
      </p>
      <a
      href="https://www.buymeacoffee.com/msabaq"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-6 py-3 bg-yellow-500 hover:bg-yellow-400 text-black font-semibold rounded-lg transition-colors duration-200 shadow-lg hover:shadow-xl"
      >
      ☕ Buy me a coffee
      </a>
      </div>
      </div>
    </footer>
  </body>
</html>
